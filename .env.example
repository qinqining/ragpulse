# =============================================================================
# ragpulse 环境变量示例
# 使用：cp .env.example .env 后按需填写密钥与路径
# =============================================================================

# ----- HTTP 服务（main.py / uvicorn）-----
HOST=0.0.0.0
PORT=8000

# ----- 对话记忆 SQLite（common/settings.py）-----
MESSAGES_DB_PATH=data/messages.db

# ----- 文档引擎 / 解析并发 -----
# 设为 true 时 nlp 分词对 Infinity 引擎走直通（一般保持未设置即可）
# DOC_ENGINE_INFINITY=false
# PDF/OCR 并行路数，0=不并行，1=单路
PARALLEL_DEVICES=1

# ----- 向量库 Chroma -----
VECTOR_DB_DIR=vector_db/chroma
# 入库时 Chroma collection.add 分批（0=一次性写入，与旧 LangChain 分批类似可设 128~512）
# RAG_CHROMA_ADD_BATCH_SIZE=0
# 每批 add 失败重试次数与退避基数（秒）
# RAG_CHROMA_ADD_MAX_RETRIES=3
# RAG_CHROMA_ADD_RETRY_SLEEP=1.0
# 批次之间的休眠秒数（可选，减轻本地磁盘压力）
# RAG_CHROMA_ADD_BATCH_PAUSE_SEC=0

# RAG 检索/入库 manifest 默认导出目录（json_export.suggest_* 自动文件名用）
RAG_EXPORT_DIR=data/rag_exports

# PDF 入库：内嵌图导出到 web/static/images，metadata.image_uri 为相对路径 JSON 列表（无域名）
# RAG_EXTRACT_PDF_IMAGES=true
# RAG_PDF_MAX_IMAGES_PER_PAGE=32

# RAG 全链路终端输出：1 / true / yes / on（print 到 stderr + logging）
# RAG_VERBOSE=1

# 入库进度：[ingest] 打到 stderr（默认开）；设为 0 可关
# RAG_INGEST_PROGRESS=1

# PDF 且 pdf_doc_type=paper（或 auto 识别为论文）时走 rag.app.paper.chunk（RAGFlow 论文分块）
# RAG_PAPER_LAYOUT_RECOGNIZE=DeepDOC
# RAG_PAPER_LANG=Chinese
# RAG_PAPER_CHUNK_DELIMITER=\n!?。；！？
# RAG_PAPER_TABLE_CONTEXT=0
# RAG_PAPER_IMAGE_CONTEXT=0

# ----- RAG 检索作用域（main.py /rag/retrieve 演示）-----
RAG_USER_ID=default
RAG_DEPT=default
RAG_KB_ID=default

# ----- 大模型：OpenAI 兼容 Chat（rag/llm/chat_model.py）-----
# 百炼 compatible-mode 示例：https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
LLM_API_URL=
# 可与通义 DashScope 共用同一 Key；也可用单独的业务 Key
LLM_API_KEY=
LLM_MODEL=qwen-plus
# RAG 问答多模态：视觉模型（百炼 compatible-mode 下 qwen-vl-plus / qwen-vl-max 等）
# LLM_VISION_MODEL=qwen-vl-plus

# 公网访问本服务的根 URL（勿尾斜杠）。入库图片在 /static/images/…，云厂商拉图做 VLM 时必须能访问
# RAG_PUBLIC_BASE_URL=https://your-server.example.com

# ----- 多模态 / 图片描述（deepdoc、rag/app/picture.py）-----
# 不填则回退为 LLM_MODEL；需支持 vision 的模型名，如 qwen-vl-plus
VISION_MODEL=qwen-vl-plus

# ----- 嵌入：DashScope text-embedding（rag/embedding/qwen_embed.py）-----
# 可与 LLM_API_KEY 相同（通义）
EMBEDDING_API_KEY=
# 默认已为 DashScope 嵌入端点，一般无需改
# EMBEDDING_API_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding
EMBEDDING_MODEL=text-embedding-v3
# 嵌入请求：超时（秒）、失败重试次数、重试基础等待（指数退避）、条与条之间间隔（防限流，0 表示不隔）
# EMBEDDING_TIMEOUT=120
# EMBEDDING_MAX_RETRIES=5
# EMBEDDING_RETRY_SLEEP=1.0
# EMBEDDING_INTERVAL_SEC=0.12

# ----- deepdoc：版面 / 表格（可选）-----
LAYOUT_RECOGNIZER_TYPE=onnx
TABLE_STRUCTURE_RECOGNIZER_TYPE=onnx
TABLE_AUTO_ROTATE=true
# 昇腾布局设备 ID（若使用对应后端）
# ASCEND_LAYOUT_RECOGNIZER_DEVICE_ID=0

# TensorRT DLA 服务地址（仅在使用 layout_recognizer 的 TENSORRT 路径时需要）
# TENSORRT_DLA_SVR=

# ----- GPU（deepdoc OCR 等，按需）-----
# CUDA_VISIBLE_DEVICES=0
